PORT=9010
HOST=127.0.0.1

# URL of widget iframe page (frontend app route)
# Example local: http://localhost:3000/roy/widget-iframe
WIDGET_IFRAME_URL=http://localhost:3000/roy/widget-iframe

# Must match partner_id configured on Roy backend side
PARTNER_ID=partner-poc-jwe

# Cookie read by parent page JS and sent back to iframe in ROY_WIDGET_JWE_RESPONSE
JWE_COOKIE_NAME=roy_widget_jwe

# 32-byte key recommended for dir + A256GCM.
# IMPORTANT: this key must match backend partner config jwe_decryption_key for PARTNER_ID.
PARTNER_JWE_KEY=0123456789abcdef0123456789abcdef

# Optional claims checks (should match Roy backend partner config if configured there)
JWE_ISSUER=partner-poc-jwe
JWE_AUDIENCE=roy-widget

# Allowed widget origins for postMessage origin checks (comma-separated)
# Example: http://localhost:3000,https://eckard.opexa-llc.com
ALLOWED_WIDGET_ORIGINS=http://localhost:3000
